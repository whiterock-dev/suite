# Copy to .env.local and fill from Firebase Console → Project settings → Your apps.
# Enable Google sign-in: Authentication → Sign-in method → Google.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Google Analytics for Firebase (same as measurementId in console)
VITE_FIREBASE_MEASUREMENT_ID=

