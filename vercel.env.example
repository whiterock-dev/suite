# Whiterock Suite — variables for Vercel
#
# Dashboard: https://vercel.com → your project → Settings → Environment Variables
# Add each variable for Production (and Preview if you want previews to work).
# Framework preset: Vite — `npm run build` will receive these automatically.
#
# Do not commit real values; copy this file to vercel.env locally and fill it,
# or paste lines one by one in Vercel.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
